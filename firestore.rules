rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }
    function existing() { 
      return resource.data; 
    }
    function isSignedIn() { 
      return request.auth != null && request.auth.uid != null; 
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['userId', 'assetClass', 'symbol', 'direction', 'entryDate', 'exitDate', 'entryPrice', 'exitPrice', 'quantity', 'fees', 'rMultiple', 'setup', 'netPnL', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.assetClass is string && data.assetClass.size() <= 20 &&
             data.symbol is string && data.symbol.size() <= 20 &&
             data.direction is string && data.direction.size() <= 20 &&
             data.entryDate is string && data.entryDate.size() <= 50 &&
             data.exitDate is string && data.exitDate.size() <= 50 &&
             data.entryPrice is number &&
             data.exitPrice is number &&
             data.quantity is number &&
             data.fees is number &&
             data.rMultiple is number &&
             data.setup is string && data.setup.size() <= 100 &&
             data.netPnL is number &&
             ( !('stopLossPrice' in data) || data.stopLossPrice is number ) &&
             ( !('takeProfitPrice' in data) || data.takeProfitPrice is number ) &&
             ( !('executionErrors' in data) || (data.executionErrors is list && data.executionErrors.size() <= 10 && (data.executionErrors.size() > 0 ? data.executionErrors[0] is string : true)) ) &&
             ( !('thesis' in data) || (data.thesis is string && data.thesis.size() <= 2000) ) &&
             ( !('screenshotUrl' in data) || (data.screenshotUrl is string && data.screenshotUrl.size() <= 500) ) &&
             ( !('notes' in data) || (data.notes is string && data.notes.size() <= 2000) );
    }

    function isValidSentiment(data) {
      return data.keys().hasAll(['userId', 'date', 'mood', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.size() <= 50 &&
             data.mood is string && data.mood.size() <= 50 &&
             ( !('notes' in data) || (data.notes is string && data.notes.size() <= 2000) );
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'project', 'priority', 'dueDate', 'completed', 'repeat', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.project is string && data.project.size() <= 100 &&
             data.priority is string && data.priority.size() <= 20 &&
             data.dueDate is string && data.dueDate.size() <= 50 &&
             data.completed is bool &&
             data.repeat is string && data.repeat.size() <= 20;
    }

    function isValidSmcSettings(data) {
      return data.keys().hasAll(['userId', 'activeAsset', 'activeTimeframe', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.activeAsset is string && data.activeAsset.size() <= 50 &&
             data.activeTimeframe is string && data.activeTimeframe.size() <= 20;
    }

    function isValidUserSettings(data) {
      return ( !('onboardingCompleted' in data) || data.onboardingCompleted is bool ) &&
             ( !('tradingTypes' in data) || data.tradingTypes is list ) &&
             ( !('goals' in data) || data.goals is list ) &&
             ( !('source' in data) || data.source is string && data.source.size() <= 100 );
    }

    match /users/{userId} {
      match /profile/settings {
        allow get: if isSignedIn() && userId == request.auth.uid;
        
        allow write: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidUserSettings(incoming()) && 
                         ( !('updatedAt' in incoming()) || incoming().updatedAt == request.time );
      }

      match /trades/{tradeId} {
        allow get: if isSignedIn() && userId == request.auth.uid && isValidId(tradeId) && resource.data.userId == request.auth.uid;
        allow list: if isSignedIn() && userId == request.auth.uid && resource.data.userId == request.auth.uid;
        
        allow create: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(tradeId) && 
                         isValidTrade(incoming()) && 
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time;
        
        allow update: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(tradeId) && 
                         resource.data.userId == request.auth.uid &&
                         isValidTrade(incoming()) && 
                         incoming().userId == existing().userId && 
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly([
                           'assetClass', 'symbol', 'direction', 'entryDate', 'exitDate', 
                           'entryPrice', 'exitPrice', 'stopLossPrice', 'takeProfitPrice', 
                           'quantity', 'fees', 'rMultiple', 'setup', 'netPnL', 
                           'executionErrors', 'thesis', 'screenshotUrl', 'notes', 'updatedAt'
                         ]);
                         
        allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(tradeId) && resource.data.userId == request.auth.uid;
      }

      match /sentiments/{sentimentId} {
        allow get: if isSignedIn() && userId == request.auth.uid && isValidId(sentimentId) && resource.data.userId == request.auth.uid;
        allow list: if isSignedIn() && userId == request.auth.uid && resource.data.userId == request.auth.uid;
        
        allow create: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(sentimentId) && 
                         isValidSentiment(incoming()) && 
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time;
        
        allow update: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(sentimentId) && 
                         resource.data.userId == request.auth.uid &&
                         isValidSentiment(incoming()) && 
                         incoming().userId == existing().userId && 
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly([
                           'date', 'mood', 'notes', 'updatedAt'
                         ]);
                         
        allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(sentimentId) && resource.data.userId == request.auth.uid;
      }

      match /tasks/{taskId} {
        allow get: if isSignedIn() && userId == request.auth.uid && isValidId(taskId) && resource.data.userId == request.auth.uid;
        allow list: if isSignedIn() && userId == request.auth.uid && resource.data.userId == request.auth.uid;
        
        allow create: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(taskId) && 
                         isValidTask(incoming()) && 
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time;
        
        allow update: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(taskId) && 
                         resource.data.userId == request.auth.uid &&
                         isValidTask(incoming()) && 
                         incoming().userId == existing().userId && 
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly([
                           'title', 'project', 'priority', 'dueDate', 'completed', 'repeat', 'updatedAt'
                         ]);
                         
        allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(taskId) && resource.data.userId == request.auth.uid;
      }

      match /smc_settings/{settingId} {
        allow get: if isSignedIn() && userId == request.auth.uid && isValidId(settingId) && resource.data.userId == request.auth.uid;
        allow list: if isSignedIn() && userId == request.auth.uid && resource.data.userId == request.auth.uid;
        
        allow create: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(settingId) && 
                         isValidSmcSettings(incoming()) && 
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time;
        
        allow update: if isSignedIn() && 
                         userId == request.auth.uid && 
                         isValidId(settingId) && 
                         resource.data.userId == request.auth.uid &&
                         isValidSmcSettings(incoming()) && 
                         incoming().userId == existing().userId &&
                         ( !('createdAt' in existing()) || incoming().createdAt == existing().createdAt ) &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly([
                           'activeAsset', 'activeTimeframe', 'updatedAt'
                         ]);
                         
        allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(settingId) && resource.data.userId == request.auth.uid;
      }
    }
  }
}
